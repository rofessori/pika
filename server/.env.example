# Copy to .env and adjust. All values are optional; defaults shown.

# Network
HOST=127.0.0.1
PORT=8787
# Hops of X-Forwarded-* to trust (nginx or cloudflared in front = 1).
TRUST_PROXY=1
# Absolute base used for share links. Leave empty to derive from the request.
BASE_URL=

# Path to the compiled pika CLI (from core/). Use an absolute path if it is
# not on the service account's PATH.
PIKA_BIN=pika

# Where readings and auth state are written.
DATA_DIR=./data
# Built frontend directory (vite output).
WEB_DIR=../web/dist

# Public developer API. When false (default) only the first-party web app
# works; the /v1 API returns 403. Tokens can still be managed in the console.
PUBLIC_API=false

# Limits
MAX_TEXT_BYTES=1048576        # 1 MiB pasted text
MAX_FILE_BYTES=8388608        # 8 MiB uploads / fetched URLs
MAX_TOKENS=200000             # cap on words per reading
READING_TTL_DAYS=30           # shareable links expire after this many days
MAX_READINGS=50000
FETCH_TIMEOUT_MS=20000
PARSE_TIMEOUT_MS=15000

# Rate limiting (per minute)
RATE_WINDOW_MS=60000
RATE_APP_MAX=60               # first-party app, per IP
RATE_API_MAX=120              # developer API, per token
